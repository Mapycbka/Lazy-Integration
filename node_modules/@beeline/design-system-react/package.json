{
	"name": "@beeline/design-system-react",
	"version": "2.1.2",
	"type": "module",
	"module": "build/index.js",
	"exports": {
		".": {
			"types": "./types/index.d.ts",
			"import": "./build/index.js",
			"default": "./build/index.js"
		},
		"./extracted-styles": {
			"types": "./types/index.d.ts",
			"import": "./extracted-styles/esm/index.js",
			"default": "./extracted-styles/esm/index.js"
		},
		"./extracted-styles/esm/index.css": {
			"style": "./extracted-styles/esm/index.css",
			"default": "./extracted-styles/esm/index.css"
		},
		"./extracted-styles/index.css": {
			"style": "./extracted-styles/esm/index.css",
			"default": "./extracted-styles/esm/index.css"
		},
		"./extracted-styles/esm/components/*/*.css": {
			"style": "./extracted-styles/esm/components/*/*.css",
			"default": "./extracted-styles/esm/components/*/*.css"
		},
		"./extracted-styles/components/*/*.css": {
			"style": "./extracted-styles/esm/components/*/*.css",
			"default": "./extracted-styles/esm/components/*/*.css"
		},
		"./assets/*": {
			"default": "./build/assets/*"
		},
		"./extracted-styles/assets/*": {
			"default": "./extracted-styles/assets/*"
		},
		"./extracted-styles/esm/assets/*": {
			"default": "./extracted-styles/assets/*"
		},
		"./package.json": "./package.json"
	},
	"sideEffects": [
		"*.css",
		"*.scss",
		"./build/**/*.css",
		"./extracted-styles/**/*.css",
		"./build/**/*2.js"
	],
	"types": "types/index.d.ts",
	"files": [
		"build",
		"types",
		"extracted-styles",
		"deprecated",
		"script"
	],
	"description": "Библиотека react компонентов дизайн системы",
	"bin": {
		"design-system-react": "./script/cli.js"
	},
	"scripts": {
		"migrate-to-v2": "node script/cli.js migrate-to-v2",
		"report-react19-consumer-gaps": "node script/cli.js report-react19-consumer-gaps",
		"build": "rollup -c",
		"build:next": "rollup -c rollup.config.next.js",
		"classify": "node util/classify-components.js",
		"test": "cross-env NODE_ENV=test vitest run",
		"test:stories": "cross-env NODE_ENV=test vitest run src/test/stories.test.tsx",
		"test:watch": "cross-env NODE_ENV=test vitest",
		"test:coverage": "cross-env NODE_ENV=test vitest run --coverage",
		"test:jest": "cross-env NODE_ENV=test jest",
		"test:playwright": "cross-env NODE_ENV=test npx playwright test",
		"storybook:serve": "STORYBOOK_DISABLE_TELEMETRY=true storybook dev -p 6006",
		"start": "STORYBOOK_DISABLE_TELEMETRY=true storybook dev -p 6006",
		"storybook:build": "STORYBOOK_DISABLE_TELEMETRY=true storybook build",
		"generate": "node ./util/create-component",
		"updateExports": "node ./util/update-export",
		"prepublishOnly": "npm run build",
		"postinstall": "node script/notice-v2.js && node script/postinstall.js && node script/component-statistic.js",
		"posti": "node script/postinstalal.js && node script/component-statistic.js && node script/notice-v2.js",
		"bundlemon": "bundlemon",
		"bundlemon:ci": "bundlemon --ci",
		"build:bundlemon": "npm run build && npm run bundlemon",
		"lint": "biome check src/",
		"lint:fix": "biome check --write src/",
		"lint:scss": "stylelint \"src/**/*.{scss,css}\"",
		"lint:scss:fix": "stylelint \"src/**/*.{scss,css}\" --fix",
		"report:token-graph:all": "node scripts/report-token-graph.js --filter=all && cp reports/tokens-graph.md reports/tokens-graph.all.md && node scripts/report-token-graph.js --filter=problems && cp reports/tokens-graph.md reports/tokens-graph.problems.md && node scripts/report-token-graph.js --filter=ok && cp reports/tokens-graph.md reports/tokens-graph.ok.md",
		"format": "biome format src/",
		"format:fix": "biome format --write src/",
		"prepare": "husky install",
		"commit": "git-cz",
		"update-scopes": "node scripts/update-commitizen-scopes.js",
		"semantic-release": "semantic-release",
		"semantic-release-dry-run": "semantic-release --dry-run",
		"check-exports": "attw --pack .",
		"migrate-tokens": "node scripts/migrate-design-tokens.js"
	},
	"repository": {
		"type": "git",
		"url": "ssh://git@git.vimpelcom.ru:1122/common/design-system-react.git"
	},
	"keywords": [
		"React",
		"Component",
		"Library",
		"Rollup",
		"Typescript",
		"Sass",
		"Storybook"
	],
	"author": {
		"email": "anaserebrennikov@beeline.ru",
		"name": "Andrew Serebrennikov"
	},
	"license": "ISC",
	"homepage": "https://git.vimpelcom.ru/common/design-system-react",
	"peerDependencies": {
		"@beeline/design-tokens": "^1.32.8",
		"imask": "^7.4.0",
		"react": "^18.2.0 || ^19.2.1",
		"react-dom": "^18.2.0 || ^19.2.1",
		"react-imask": "^7.4.0"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.16.4",
		"@babel/core": "^7.20.12",
		"@babel/preset-env": "^7.23.9",
		"@babel/preset-react": "^7.23.3",
		"@babel/preset-typescript": "^7.23.3",
		"@biomejs/biome": "2.0.4",
		"@commitlint/cli": "^19.2.2",
		"@commitlint/config-conventional": "^19.2.2",
		"@digitalroute/cz-conventional-changelog-for-jira": "^8.0.1",
		"@faker-js/faker": "^7.6.0",
		"@mdx-js/react": "^1.6.22",
		"@playwright/test": "^1.43.1",
		"@rollup/plugin-commonjs": "^25.0.7",
		"@rollup/plugin-image": "^3.0.3",
		"@rollup/plugin-node-resolve": "15.3.0",
		"@rollup/plugin-terser": "^0.4.4",
		"@semantic-release/changelog": "5.0.1",
		"@semantic-release/exec": "^5.0.0",
		"@semantic-release/git": "9.0.1",
		"@semantic-release/gitlab": "6.2.2",
		"@storybook/addon-docs": "10.2.1",
		"@storybook/addon-links": "10.2.1",
		"@storybook/builder-vite": "10.2.1",
		"@storybook/icons": "^1.2.9",
		"@storybook/preset-scss": "^1.0.3",
		"@storybook/react": "10.2.1",
		"@storybook/react-vite": "10.2.1",
		"@tanstack/react-table": "^8.7.9",
		"@temptek/semantic-release-jira": "^0.3.2",
		"@testing-library/jest-dom": "^5.16.4",
		"@testing-library/react": "^16.3.0",
		"@testing-library/user-event": "^14.4.3",
		"@types/jest": "^28.1.8",
		"@types/mdx": "^2.0.3",
		"@types/node": "^20.17.0",
		"@types/react": "^19.2.3",
		"@types/react-dom": "^19.2.3",
		"@vitest/coverage-v8": "^1.4.0",
		"@welldone-software/why-did-you-render": "^10.0.1",
		"babel-loader": "^9.1.2",
		"babel-preset-react-app": "^10.0.1",
		"bundlemon": "^3.1.0",
		"commitizen": "^4.3.0",
		"cross-env": "^7.0.3",
		"css-loader": "^6.7.1",
		"fs-extra": "^10.1.0",
		"glob": "^10.5.0",
		"husky": "^9.0.10",
		"imask": "^7.4.0",
		"identity-obj-proxy": "^3.0.0",
		"jest": "^28.1.3",
		"jest-environment-jsdom": "^28.1.3",
		"jsdom": "^24.0.0",
		"lint-staged": "^15.2.0",
		"react": "^19.2.3",
		"react-dom": "^19.2.3",
		"react-imask": "^7.4.0",
		"react-pdf": "^10.2.0",
		"react-syntax-highlighter": "^15.5.0",
		"resize-observer-polyfill": "^1.5.1",
		"rollup": "^2.79.1",
		"rollup-plugin-copy": "^3.5.0",
		"rollup-plugin-delete": "^2.0.0",
		"rollup-plugin-generate-package-json": "^3.2.0",
		"rollup-plugin-peer-deps-external": "^2.2.4",
		"rollup-plugin-postcss": "^4.0.2",
		"rollup-plugin-preserve-directives": "^0.4.0",
		"rollup-plugin-typescript2": "^0.36.0",
		"sass": "1.91.0",
		"sass-loader": "^16.0.5",
		"semantic-release": "17.4.7",
		"semantic-release-jira": "^3.0.0",
		"semantic-release-jira-releases": "^0.7.2",
		"storybook": "10.2.1",
		"storybook-multilevel-sort": "^2.0.0",
		"style-loader": "^3.3.1",
		"stylelint": "^16.23.1",
		"stylelint-config-standard-scss": "^15.0.1",
		"stylelint-scss": "^6.12.1",
		"ts-jest": "^28.0.8",
		"ts-node": "^10.9.2",
		"ts-pattern": "^5.9.0",
		"tsconfig-paths-webpack-plugin": "^4.0.0",
		"typescript": "^5.2.0",
		"vite": "^7.3.1",
		"vite-tsconfig-paths": "^6.0.5",
		"vitest": "^1.4.0",
		"webpack-bundle-analyzer": "^4.10.1"
	},
	"publishConfig": {
		"registry": "https://nexus.vimpelcom.ru/repository/common__npm/"
	},
	"dependencies": {
		"@babel/plugin-proposal-private-property-in-object": "^7.21.11",
		"@floating-ui/react": "^0.26.5",
		"date-fns": "^2.29.1",
		"date-fns-tz": "^1.3.6",
		"docx-preview": "^0.3.7",
		"react-helmet-async": "^3.0.0",
		"react-pdf": "^10.2.0",
		"react-scanner": "^1.1.0",
		"run": "^1.5.0"
	},
	"overrides": {
		"@mdx-js/react": {
			"react": "$react"
		}
	},
	"config": {
		"commitizen": {
			"path": "./commitizen.config.cjs"
		}
	},
	"optionalDependencies": {
		"@rollup/rollup-darwin-arm64": "^4.59.0",
		"@rollup/rollup-darwin-x64": "^4.59.0",
		"@rollup/rollup-linux-x64-gnu": "^4.59.0"
	}
}
