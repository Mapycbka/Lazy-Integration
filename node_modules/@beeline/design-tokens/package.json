{
  "name": "@beeline/design-tokens",
  "scope": "@beeline",
  "version": "1.32.9",
  "description": "Beeline design system tokens",
  "bin": {
    "ds-migrate": "./migrator/migrator.js"
  },
  "scripts": {
    "prebuild-test": "jest test/prebuild/",
    "build": "node script/svg-fixer.js && node build.js && npm run build:migrator",
    "build:migrator": "cross-env TS_NODE_PROJECT=\\\"tsconfig.json\\\" webpack && node migrator/buildtools/add-shebang-to-migrator.mjs",
    "build:migration": "node build-scripts/migrations/build.js",
    "prerelease": "node copy-docs.js",
    "release": "semantic-release",
    "prepublishOnly": "cp ../../CHANGELOG.md .",
    "postversion": "cp package.json package-lock.json ../..",
    "commit": "git-cz",
    "pack": "npm run build && node script/generate-exports.js && npm run prerelease && cd dist/web && npm pack",
    "link": "npm run build && node script/generate-exports.js && npm run prerelease && cd dist/web && npm link",
    "generate-exports": "node script/generate-exports.js",
    "dev-migrator:watch": "cross-env TS_NODE_PROJECT=\"tsconfig.json\" webpack --watch",
    "postinstall": "node script/postinstall.js",
    "posti": "node script/postinstalal.js"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "repository": {
    "type": "git",
    "url": "ssh://git@git.vimpelcom.ru:1122/products/design-system/design-tokens.git"
  },
  "author": {
    "email": "kvandrusova@beeline.ru",
    "name": "Kseniia Andrusova"
  },
  "license": "ISC",
